@{
    Layout = "_Layout";
}

<div class="container mt-4">

    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row">

        <!-- Total Products -->
        <div class="col-md-4">

            <div class="card text-white bg-primary shadow">

                <div class="card-body">

                    <h5 class="card-title">Total Products</h5>

                    <h3>@ViewBag.TotalProducts</h3>

                </div>

            </div>

        </div>

        <!-- Add Product -->
        <div class="col-md-4">

            <div class="card text-white bg-success shadow">

                <div class="card-body text-center">

                    <h5>Add Bakery Product</h5>

                    <a href="/Product/Create" class="btn btn-light mt-2">

                        Add Product

                    </a>

                </div>

            </div>

        </div>

        <!-- View Products -->
        <div class="col-md-4">

            <div class="card text-white bg-warning shadow">

                <div class="card-body text-center">

                    <h5>Manage Products</h5>

                    <a href="/Product" class="btn btn-light mt-2">

                        View Products

                    </a>

                </div>

            </div>

        </div>

    </div>

    <hr class="my-4">

    <h4>Bakery Information</h4>

    <div class="row mt-3">

        <div class="col-md-6">

            <p><b>Shop Name:</b> Modern Bakery</p>

            <p><b>Location:</b> Ooty Varkey Bakery, Ooty, Tamil Nadu</p>

            <p><b>Phone:</b> +91 8072786037</p>

            <p><b>Opening Time:</b> 9:30 AM - 09:00 PM</p>

        </div>

        <div class="col-md-6">

            <iframe width="100%" height="250"
                    src="https://maps.google.com/maps?q=ooty&t=&z=13&ie=UTF8&iwloc=&output=embed">
            </iframe>

        </div>

    </div>

</div>