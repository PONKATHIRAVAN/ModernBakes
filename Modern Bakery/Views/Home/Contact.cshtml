@model BakeryShop.Models.ContactMessage

<style>
    /* LIGHT GRAY BACKGROUND */
    .contact-bg {
        background: #f2f4f7; /* light gray */
        padding: 60px 0;
        min-height: 100vh;
    }

    /* GLASS EFFECT CARD */
    .contact-box {
        background: rgba(255, 255, 255, 0.6); /* more transparent */
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 25px;
        padding: 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        transition: 0.4s ease;
        border: 1px solid rgba(255,255,255,0.3);
    }

        .contact-box:hover {
            transform: perspective(1200px) rotateX(3deg) rotateY(-3deg);
            box-shadow: 0 30px 70px rgba(0,0,0,0.2);
        }

    /* info hover */
    .contact-info p {
        padding: 8px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
    }

        .contact-info p:hover {
            background: rgba(255,255,255,0.6);
            transform: translateX(10px);
        }

    /* input style */
    .form-control {
        border-radius: 12px;
        border: 1px solid #ddd;
        transition: 0.3s;
        background: rgba(255,255,255,0.7);
    }

        .form-control:focus {
            box-shadow: 0 0 10px rgba(13,110,253,0.3);
            transform: scale(1.02);
        }

    /* gradient button */
    .btn-primary {
        background: linear-gradient(45deg,#007bff,#00c6ff);
        border: none;
        border-radius: 30px;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

    /* whatsapp button */
    .btn-success {
        border-radius: 30px;
        transition: 0.3s;
    }

        .btn-success:hover {
            box-shadow: 0 0 15px rgba(25,135,84,0.6);
            transform: scale(1.03);
        }

    /* floating animation */
    .float {
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    /* fade */
    .fade-in {
        animation: fadeIn 1s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* map style */
    .map-frame {
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
    }

        .map-frame:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
</style>

<div class="contact-bg">

    <div class="container fade-in">

        <div class="row justify-content-center">

            <div class="col-md-10">

                <div class="contact-box float">

                    <h2 class="text-center mb-4">📞 Contact Us</h2>

                    <div class="row">

                        <!-- LEFT -->
                        <div class="col-md-6 contact-info">

                            <h4>🏪 Bakery Details</h4>

                            <p>🏬 Morden Bakery</p>
                            <p>📍 Ooty, Tamil Nadu</p>
                            <p>📞 +91 8072786037</p>
                            <p>📧 ponkathiravanselvam@outlook.com</p>
                            <p>⏰ 9:30 AM – 9:00 PM</p>

                            <br>

                            <a href="https://wa.me/918072786037"
                               class="btn btn-success w-100">
                                💬 Chat on WhatsApp
                            </a>

                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-6">

                            <form method="post">

                                <div class="mb-3">
                                    <label>Name</label>
                                    <input asp-for="Name" class="form-control">
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Email</label>
                                    <input asp-for="Email" class="form-control">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Message</label>
                                    <textarea asp-for="Message" class="form-control"></textarea>
                                    <span asp-validation-for="Message" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label>Rating</label>
                                    <select asp-for="Rating" class="form-control">
                                        <option value="">Select Rating</option>
                                        <option value="5">⭐⭐⭐⭐⭐</option>
                                        <option value="4">⭐⭐⭐⭐</option>
                                        <option value="3">⭐⭐⭐</option>
                                        <option value="2">⭐⭐</option>
                                        <option value="1">⭐</option>
                                    </select>
                                </div>

                                <button class="btn btn-primary w-100">
                                    Send Message
                                </button>

                            </form>

                        </div>

                    </div>

                    <hr>

                    <h5 class="text-center mt-3">📍 Our Location</h5>

                    <div class="map-frame">
                        <iframe width="100%" height="250"
                                src="https://maps.google.com/maps?q=ooty&t=&z=13&ie=UTF8&iwloc=&output=embed">
                        </iframe>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>