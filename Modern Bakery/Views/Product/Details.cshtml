@model BakeryShop.Models.Product

<style>
    .product-detail-card {
        border-radius: 20px;
        padding: 20px;
        background: #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        transition: 0.4s ease;
    }

        .product-detail-card:hover {
            transform: perspective(1000px) rotateX(3deg) rotateY(-3deg) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

    .product-image {
        transition: 0.5s;
        cursor: pointer;
    }

        .product-image:hover {
            transform: scale(1.05) rotateZ(1deg);
        }

    .product-title {
        font-weight: 700;
    }

    .price-style {
        font-size: 26px;
        font-weight: 600;
    }

    .fade-in {
        animation: fadeIn 0.8s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container mt-5 fade-in">

    <div class="row align-items-center product-detail-card">

        <div class="col-md-6 text-center">

            <img src="~/images/@Model.ImagePath"
                 class="img-fluid rounded shadow product-image"
                 style="max-height:400px; object-fit:cover;">

        </div>

        <div class="col-md-6">

            <h2 class="product-title">@Model.Name</h2>

            <h4 class="text-success price-style">₹@Model.Price</h4>

            <p>
                Fresh bakery product made with high quality ingredients.
                Available every day in our bakery shop.
            </p>

            <p><strong>Category:</strong> @Model.Category</p>

            <br>

            <a href="/Product" class="btn btn-outline-secondary">
                Back to Products
            </a>

            @if (Context.Session.GetString("Admin") == "true")
            {
                <a href="/Product/Edit/@Model.Id"
                   class="btn btn-warning ms-2">
                    Edit
                </a>

                <a href="/Product/Delete/@Model.Id"
                   class="btn btn-danger ms-2"
                   onclick="return confirm('Are you sure you want to delete this product?');">
                    Delete
                </a>
            }

        </div>

    </div>

</div>