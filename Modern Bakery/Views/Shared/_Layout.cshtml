<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Morden Bakery</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container">

            <a class="navbar-brand" href="/">🍰 Morden Bakery</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Contact">Contact</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Product">Products</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Review">Reviews</a>
                    </li>

                    @if (Context.Session.GetString("Admin") == "true")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/AdminFeedback">Manage Feedback</a>
                        </li>
                    }

                    @if (Context.Session.GetString("Admin") == "true")
                    {
                        <li class="nav-item">
                            <a class="btn btn-danger ms-lg-2 mt-2 mt-lg-0" href="/Account/Logout">
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary text-white ms-lg-2 mt-2 mt-lg-0"
                               href="/Account/Login">
                                Admin Login
                            </a>
                        </li>
                    }

                </ul>
              

            </div>

        </div>
        

    </nav>

    <div class="container mt-4">

        @RenderBody()

    </div>

    <footer class="bg-dark text-white text-center p-3 mt-5">

        <p>© 1980 Morden Bakery Shop</p>
        <p>📍 Ooty, Tamil Nadu | 📞 +91 8072786037 </p>

    </footer>

    <!-- IMPORTANT: Bootstrap JS for responsive navbar -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>